# Authentication
AUTH_PEPPER=change-me-to-a-long-random-string
SESSION_SECRET=change-me-to-another-long-random-string

# Admin Seeding
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-secure-password

# Registration
ALLOW_REGISTRATION=false

# Database
DATABASE_URL=file:./data/koalasnippets.db

# Backups
BACKUP_DIR=./backups

# Environment
NODE_ENV=development
