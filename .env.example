# Authentication
AUTH_PEPPER=change-me-to-a-long-random-string
SESSION_SECRET=change-me-to-another-long-random-string

# Admin Seeding
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Registration
ALLOW_REGISTRATION=false

# Database
DATABASE_URL=file:./data/koalasnippets.db

# Backups
BACKUP_DIR=./backups

# Optional: Shared secret for programmatic API access (bypasses CSRF checks)
# API_KEY=your-api-key-here

# Optional: Contact email displayed in privacy/imprint pages
# CONTACT_EMAIL=admin@example.com

# Environment
NODE_ENV=development
